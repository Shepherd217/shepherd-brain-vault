{
  "id": "checkpoint-v2",
  "name": "Checkpoint v2",
  "description": "Automatic workspace snapshots with pruning and disk guardrails. Creates periodic backups of critical files, auto-deletes old ones, and prevents disk fill-up.",
  "contracts": {
    "tools": ["create_checkpoint", "list_checkpoints", "restore_checkpoint", "delete_checkpoint"]
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "checkpointDir": {
        "type": "string",
        "default": "~/.openclaw/checkpoints"
      },
      "maxCheckpoints": {
        "type": "number",
        "default": 20
      },
      "maxTotalSizeMb": {
        "type": "number",
        "default": 500
      },
      "autoCheckpointIntervalMinutes": {
        "type": "number",
        "default": 30
      },
      "criticalFiles": {
        "type": "array",
        "items": { "type": "string" },
        "default": [
          "SOUL.md",
          "USER.md",
          "MEMORY.md",
          "AGENTS.md",
          "IDENTITY.md",
          "TOOLS.md",
          "HEARTBEAT.md",
          ".coordination/tasks/task-board.md"
        ]
      }
    }
  }
}
