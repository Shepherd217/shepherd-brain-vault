{
  "id": "openclaw-platform-allowlist",
  "name": "Platform Allowlist Enforcer",
  "description": "Enforces per-agent platform/channel allowlists. Prevents agents from sending messages to unauthorized platforms. Logs violations for audit.",
  "version": "1.0.0",
  "author": "Ava",
  "license": "MIT",
  "extensions": [
    {
      "id": "platform-allowlist",
      "name": "Platform Allowlist",
      "type": "tool",
      "entry": "index.js",
      "config": {
        "schema": {
          "defaultPolicy": {
            "type": "string",
            "enum": ["allow", "deny"],
            "default": "deny"
          },
          "logFile": {
            "type": "string",
            "default": "~/.openclaw/logs/allowlist-violations.jsonl"
          }
        }
      }
    }
  ],
  "permissions": {
    "fs": {
      "read": ["**/*"],
      "write": ["**/*"]
    }
  }
}
