{
  "id": "openclaw-checkpoint-v2",
  "name": "Checkpoint v2",
  "description": "Automatic workspace snapshots with pruning and disk guardrails. Creates periodic backups of critical files, auto-deletes old ones, and prevents disk fill-up.",
  "version": "1.0.0",
  "author": "Ava",
  "license": "MIT",
  "extensions": [
    {
      "id": "checkpoint-v2",
      "name": "Checkpoint System",
      "type": "tool",
      "entry": "index.js",
      "config": {
        "schema": {
          "checkpointDir": {
            "type": "string",
            "default": "~/.openclaw/checkpoints"
          },
          "maxCheckpoints": {
            "type": "integer",
            "default": 20
          },
          "maxTotalSizeMb": {
            "type": "integer",
            "default": 500
          },
          "autoCheckpointIntervalMinutes": {
            "type": "integer",
            "default": 30
          },
          "criticalFiles": {
            "type": "array",
            "items": { "type": "string" },
            "default": [
              "SOUL.md",
              "USER.md",
              "MEMORY.md",
              "AGENTS.md",
              "IDENTITY.md",
              "TOOLS.md",
              "HEARTBEAT.md",
              ".coordination/tasks/task-board.md"
            ]
          }
        }
      }
    }
  ],
  "permissions": {
    "fs": {
      "read": ["**/*"],
      "write": ["**/*"]
    }
  }
}